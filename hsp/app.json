{
  "expo": {
    "name": "HSP",
    "slug": "hsp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon/diseño_3caja_x1024.png",
    "scheme": "hsp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#002060",
        "foregroundImage": "./assets/icon/diseño_3caja_x512.png",
        "backgroundImage": "./assets/icon/diseño_3caja_x512.png",
        "monochromeImage": "./assets/icon/diseño_3caja_x432.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon/diseño_3caja_x48.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon/diseño_3caja_x1024.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#456bd5",
          "dark": {
            "backgroundColor": "#002060"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
